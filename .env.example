# Default SQLite file lives at ./.data/openframe.db (gitignored)
DATABASE_PATH=.data/openframe.db

# Drizzle CLI also accepts DATABASE_URL for sqlite file URLs
# DATABASE_URL=file:./.data/openframe.db

# Motion Pro (GSAP timelines + ScrollTrigger). Set to 1 to enable runtime; omit or 0 for Open-Core-only preview.
# NEXT_PUBLIC_OPENFRAME_MOTION_PRO=1
